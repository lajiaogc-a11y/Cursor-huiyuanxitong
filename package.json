{
  "name": "giftcard-member-system",
  "private": true,
  "version": "1.1.2",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "dev:all": "node scripts/dev-all.mjs",
    "api:dev": "cd server && npm run dev",
    "api:install": "cd server && npm install",
    "db:sync:pull": "node scripts/sync-mysql-remote-to-local.mjs",
    "db:lottery-mysql": "cd server && npm run migrate:lottery",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "lint:server": "eslint server/src",
    "arch:gate": "node scripts/architecture-gate.mjs",
    "smoke:api": "node ./scripts/smoke-api.mjs",
    "reference:elite-pack": "node scripts/generate-member-ui-reference.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "preview": "vite preview",
    "deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-full.ps1",
    "publish": "powershell -ExecutionPolicy Bypass -File ./scripts/push-to-github.ps1",
    "deploy:full": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-full.ps1",
    "deploy:full:msg": "node ./scripts/deploy-full-with-msg.mjs",
    "deploy:release": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-full.ps1",
    "deploy:remote-api": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-remote-node-api.ps1",
    "restart:remote-migrate": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-remote-api-migrate.ps1",
    "build:electron": "cross-env VITE_BUILD_TARGET=electron vite build && electron-builder",
    "build:electron:win": "cross-env VITE_BUILD_TARGET=electron vite build && electron-builder --win",
    "build:electron:mac": "cross-env VITE_BUILD_TARGET=electron vite build && electron-builder --mac",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "build:capacitor": "cross-env VITE_BUILD_TARGET=capacitor vite build && npx cap sync",
    "cap:android": "npm run build:capacitor && npx cap open android",
    "cap:ios": "npm run build:capacitor && npx cap open ios",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "db:cleanup-unused": "node scripts/cleanup-unused-data.mjs",
    "db:cleanup-backups": "node scripts/cleanup-all-backups.mjs",
    "db:fix-order-profit": "node scripts/fix-order-profit-usdt.mjs",
    "deploy:set-password-fn": "node scripts/deploy-admin-set-password.mjs",
    "db:set-password": "node scripts/deploy-admin-set-password-db.mjs",
    "db:set-2fa-123456": "node scripts/set-employee-2fa-123456.mjs",
    "db:diagnose-2fa": "node scripts/diagnose-login-2fa.mjs",
    "db:check-tenant-002": "node scripts/check-tenant-002-data.mjs",
    "db:diagnose-tenant-data": "node scripts/diagnose-tenant-data.mjs",
    "verify:tenant-002": "node scripts/verify-tenant-002-task.mjs",
    "restore-employees": "node scripts/restore-employees.mjs",
    "restore-knowledge": "node scripts/restore-knowledge.mjs",
    "restore-full": "node scripts/restore-full.mjs",
    "restore-full-db": "node scripts/restore-full-db.mjs",
    "list-backups": "node scripts/list-backups.mjs",
    "test:login": "node scripts/test-login.mjs",
    "test:knowledge-api": "node scripts/test-knowledge-api.mjs",
    "test:data-visibility": "node scripts/test-data-visibility.mjs"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fingerprintjs/fingerprintjs": "^4.6.2",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toast": "^1.2.14",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.83.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/nprogress": "^0.2.3",
    "@types/react-helmet": "^6.1.11",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "jsdom": "^20.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "nprogress": "^0.2.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-hook-form": "^7.61.1",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^6.30.1",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.4",
    "web-vitals": "^5.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "cc.fastgc.giftsystem",
    "productName": "FastGC会员系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/pwa-512x512.png",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@eslint/js": "^9.32.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^5.4.19"
  },
  "lint-staged": {
    "*.{ts,tsx,mts,cts}": "eslint"
  }
}
