# HTML: never cache — always get latest JS references
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# Hashed JS/CSS: immutable long cache（Vite 对 CSS link 带 crossorigin，补 CORS 避免少数环境拒载）
/assets/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Fonts: long cache
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Images: moderate cache
/*.png
  Cache-Control: public, max-age=86400
/*.ico
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400

# version.json: no cache
/version.json
  Cache-Control: no-cache, no-store, must-revalidate
