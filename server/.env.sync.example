# 仅用于「线上 → 本地」同步脚本 scripts/sync-mysql-remote-to-local.mjs
# 复制本文件为 server/.env.sync 并填写真实值（server/.env.sync 请勿提交仓库）

# 方式 A：一条连接串（密码含特殊字符请 URL 编码）
# SOURCE_DATABASE_URL=mysql://admin:密码@your-db.xxxx.ap-southeast-1.rds.amazonaws.com:3306/gc_member_system

# 方式 B：分项
SOURCE_MYSQL_HOST=your-db.xxxx.ap-southeast-1.rds.amazonaws.com
SOURCE_MYSQL_PORT=3306
SOURCE_MYSQL_USER=admin
SOURCE_MYSQL_PASSWORD=
SOURCE_MYSQL_DATABASE=gc_member_system

# AWS RDS 常需 SSL（按实例要求二选一；不需要则留空）
# SOURCE_MYSQL_SSL_MODE=REQUIRED

# 可选：Windows 上 mysqldump/mysql 不在 PATH 时
# MYSQLDUMP_PATH=C:\\Program Files\\MySQL\\MySQL Server 8.0\\bin\\mysqldump.exe
# MYSQL_CLIENT_PATH=C:\\Program Files\\MySQL\\MySQL Server 8.0\\bin\\mysql.exe
