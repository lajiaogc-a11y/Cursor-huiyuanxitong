PORT=3001
NODE_ENV=development
# 认证与业务数据均为 MySQL + 本 Node API。
JWT_SECRET=change-me-to-a-strong-random-string

# 会员端 JWT 签名密钥：必须与 JWT_SECRET 独立；生产环境（NODE_ENV=production）必填，否则进程拒绝启动
# 开发可省略（使用内置占位并打警告），或设 DEV_MEMBER_JWT_SECRET 便于重启后 token 仍有效
# MEMBER_JWT_SECRET=
# DEV_MEMBER_JWT_SECRET=

# 平台租户 ID（tenants 表中 tenant_code='platform' 的 id）
# 不同环境有不同值时设置此变量，不再需要改源码
# PLATFORM_TENANT_ID=05307a8c-68f5-4fe4-a212-06439387dbd1

# 生产（NODE_ENV=production）且 API 在 Nginx/CDN/反代之后：必须 =1，express-rate-limit 才按真实客户端 IP
TRUST_PROXY=1

# 仅本地验证 trust proxy 日志（保持 NODE_ENV=development 时）：与 TRUST_PROXY=1 同时设置；npm run start:verify-trust-proxy-dev
# VERIFY_TRUST_PROXY=1

# 模拟生产启动看日志：npm run start:verify-trust-proxy
# 此时须允许本地前端 Origin，例如：
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081

# 时区（默认北京时间）：订单/抽奖「今日」与 DATETIME 展示与 MySQL 一致
# MYSQL_TIMEZONE 仅支持 ±HH:MM，例如 +08:00
# MYSQL_TIMEZONE=+08:00
# APP_TIMEZONE=Asia/Shanghai
# 未设置 TZ 时，进程启动会将 TZ 设为 APP_TIMEZONE（见 app.ts）

# MySQL（必填：员工登录与全站数据）
# 上线推荐：云厂商常提供一条连接串。仅当协议为 mysql:// 或 mysql2:// 时 API 会优先用其建池；
# 根目录脚本若使用 postgresql:// 的 DATABASE_URL，请勿写进 server/.env，以免混淆（或保持 API 只用下方 MYSQL_*）。
# DATABASE_URL=mysql://user:password@host:3306/gc_member_system
# 密码含 @ # 等字符时须 URL 编码（例如 @ → %40），否则解析会截断密码
#
# 未设置 MySQL DATABASE_URL 时仍使用分项变量（与改前行为一致）
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=gc_member_system
# 连接池上限（默认 10）；本地减负可设 2～4，生产勿随意改小
# MYSQL_POOL_LIMIT=10

# 完整库导出：mysqldump 可执行文件路径（Windows 示例：C:\\Program Files\\MySQL\\MySQL Server 8.0\\bin\\mysqldump.exe）
# MYSQLDUMP_PATH=mysqldump
# 同一用户两次导出最小间隔（毫秒），防滥用
# DUMP_MIN_INTERVAL_MS=120000

# ---------- 数据备份（定时 JSON 快照）----------
# 本地 JSON 目录，默认 <进程 cwd>/data-backups
# DATA_BACKUP_DIR=

# 系统 cron / 任务计划调用：POST /api/internal/backup/run
# 请求头二选一：X-Backup-Cron-Secret: <密钥> 或 Authorization: Bearer <密钥>
# 未设置时该接口返回 503
# BACKUP_CRON_SECRET=long-random-string

# 可选：在本 Node 进程内每 N 毫秒跑一次自动备份（多副本部署请勿用，改用上方的 cron + HTTP）
# 例如 24 小时：86400000
# BACKUP_AUTO_INTERVAL_MS=0

# Webhook 队列处理：cron 调 POST /api/internal/webhooks/process-queue
# 头：X-Webhook-Processor-Secret 或 Authorization: Bearer
# WEBHOOK_PROCESSOR_SECRET=long-random-string

# ---------- 方案 A：迁移与启动解耦 ----------
# 生产环境（NODE_ENV=production）默认不在 app 启动时跑库迁移；部署前先执行：
#   cd server && npm run build && npm run migrate:all
# 开发环境默认启动时迁移；失败则进程退出。
# 若必须在生产进程内迁移（不推荐多副本）：RUN_DB_MIGRATIONS_ON_START=1
# 强制跳过（例如纯读副本）：RUN_DB_MIGRATIONS_ON_START=0
# RUN_DB_MIGRATIONS_ON_START=
# 无可用 MySQL 时跳过会立即查库的定时任务，避免 listen 后崩溃（仅联调；有库勿开）
# SKIP_STARTUP_SCHEDULERS=1

# ---------- 方案 D：站点主机名（CORS 兜底，与前端域名对齐）----------
# 逗号分隔；未设置时默认 crm.fastgc.cc / admin.crm.fastgc.cc
# MEMBER_HOSTS=crm.fastgc.cc
# STAFF_HOSTS=admin.crm.fastgc.cc

# ---------- CSP (Content Security Policy) ----------
# 未设置 CSP_MODE 时：生产默认 enforce；开发默认 off
# off    = 不启用 CSP
# report = Content-Security-Policy-Report-Only，违规上报 /api/csp-report（预发/排障）
# enforce= 强制 CSP（本 Node 进程返回的响应；主 SPA 若在 CDN/Nginx 上需在其侧单独配 CSP）
# CSP_MODE=

# ---------- 上传图片：S3（可选）----------
# 同时设置 S3_BUCKET 与 AWS_REGION（或 S3_REGION）后，新上传写入 S3；桶保持私有，不经公开 ACL
# 凭证：AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY 或实例/任务 IAM 角色
# S3_BUCKET=
# AWS_REGION=ap-southeast-1
# S3_REGION=
# 预签名 GET 有效期（秒），默认 300，范围 60–3600
# S3_PRESIGN_EXPIRES_SEC=300
# 可选：CloudFront 根 URL（文档/扩展用；当前读图走 /api/upload 或 presign）
# S3_PUBLIC_BASE_URL=

# 邀请注册一次性凭证有效期（秒），默认 300，范围 120–600
# INVITE_REGISTER_TOKEN_TTL_SEC=300

# invite_register_tokens 定时清理：默认每 15 分钟；最小 60s
# INVITE_REGISTER_TOKEN_CLEANUP_INTERVAL_MS=900000
# 已消费 token 超过 N 天删除（默认 90）；0 = 不删已消费，只删过期未使用
# INVITE_REGISTER_TOKEN_PURGE_USED_AFTER_DAYS=90

# 邀请排行榜：系统假用户自动增长冷却（小时），默认 72；服务端每小时检测一次是否到期
# INVITE_LEADERBOARD_GROWTH_HOURS=72

# ---------- 上传图片读取鉴权 ----------
# public  (默认) = 标记为 public 的资源可匿名读（租户级 banner 等）；private 始终需员工 JWT 或 presign
# required = 在 public 基础上额外收紧（见代码注释）
# UPLOAD_IMAGE_AUTH=public

# ---------- 上传图片 WebP（POST 入库与 GET 输出共用；会员端通过 /api/upload/image/:id 始终可收到 WebP）----------
# 质量 1–100；过大时自动降质量二次编码
# UPLOAD_WEBP_QUALITY=82
# UPLOAD_WEBP_QUALITY_FALLBACK=68
# 解码后原始图最大字节（默认 15MB）
# UPLOAD_WEBP_MAX_INPUT_BYTES=15728640
# 输出 WebP 最大字节（默认 2MB）
# UPLOAD_WEBP_MAX_OUTPUT_BYTES=2097152
# 长边像素上限（默认 4096）
# UPLOAD_WEBP_MAX_PIXEL_SIDE=4096
# GET 时若库内非 WebP（历史数据），现场转 WebP；设为 0 则原样返回字节流
# UPLOAD_NORMALIZE_TO_WEBP_ON_READ=1

# ---------- 后端上线（自行在托管平台操作）----------
# 前端发布用根目录 npm run deploy:full；API 需在主机上拉代码、构建并重启进程。
# 若使用 Railway 等 PaaS，在其控制台配置环境变量并 Redeploy 即可（与前端脚本无关）。
